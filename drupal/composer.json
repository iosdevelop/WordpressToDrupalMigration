{
  "name": "prototype/wp-drupal-migration",
  "description": "Drupal 10 prototype for WordPress to Drupal migration demos.",
  "type": "project",
  "license": "MIT",
  "repositories": {
    "drupal": {
      "type": "composer",
      "url": "https://packages.drupal.org/8"
    }
  },
  "require": {
    "composer/installers": "^2.3",
    "drupal/admin_toolbar": "^3.6",
    "drupal/canvas": "^1.6",
    "drupal/core-composer-scaffold": "^11.3",
    "drupal/core-project-message": "^11.3",
    "drupal/core-recommended": "^11.3",
    "drupal/migrate_plus": "^6.0",
    "drupal/migrate_source_csv": "^3.4",
    "drupal/migrate_tools": "^6.0",
    "drupal/redirect": "^1.9",
    "drush/drush": "^13"
  },
  "conflict": {
    "drupal/drupal": "*"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "drupal/core-composer-scaffold": true,
      "drupal/core-project-message": true
    },
    "sort-packages": true
  },
  "extra": {
    "drupal-scaffold": {
      "locations": {
        "web-root": "web/"
      }
    },
    "installer-paths": {
      "web/core": [
        "type:drupal-core"
      ],
      "web/libraries/{$name}": [
        "type:drupal-library"
      ],
      "web/modules/contrib/{$name}": [
        "type:drupal-module"
      ],
      "web/profiles/contrib/{$name}": [
        "type:drupal-profile"
      ],
      "web/themes/contrib/{$name}": [
        "type:drupal-theme"
      ],
      "drush/Commands/contrib/{$name}": [
        "type:drupal-drush"
      ]
    }
  }
}
